#!/bin/bash
# /usr/bin/telnet — fake shim installed by genpack/base.
#
# genpack intentionally does NOT ship a real telnet (net-misc/netkit-telnetd was
# dropped). This shim is a rescue measure for the muscle-memory `telnet HOST PORT`
# (poking SMTP/HTTP/etc. by hand): it scolds you, teaches the modern equivalent,
# then connects you anyway. It prefers `curl telnet://` (curl actually speaks the
# telnet protocol and is present in almost every image), falling back to socat,
# ncat/nc, and finally bash's built-in /dev/tcp so it works even in a minimal
# image with none of those installed.

host=$1
port=${2:-23}

if [ -z "$host" ]; then
    echo "usage: telnet HOST [PORT]   (this is genpack's fake telnet)" >&2
    exit 2
fi

# Real telnet accepts a /etc/services name (e.g. `telnet host smtp`). socat and
# bash /dev/tcp resolve such names themselves, but curl's telnet:// wants a
# number, so normalise it up front for every backend.
case $port in
    *[!0-9]*)
        svc=$(getent services "$port" 2>/dev/null | awk '{print $2}' | cut -d/ -f1)
        [ -n "$svc" ] && port=$svc
        ;;
esac

cat >&2 <<EOF
──────────────────────────────────────────────────────────────────
You reached for telnet out of habit again. This is NOT the real
telnet — genpack does not ship net-misc/netkit-telnetd on purpose.
Fine, I'll connect you to $host:$port this once.

Next time, type one of these instead:
    curl telnet://$host:$port            # closest to telnet, curl is almost always present
    socat - TCP:$host:$port              # raw TCP (preferred for scripting)
    socat - TCP:$host:$port,crlf         # raw TCP with CRLF line endings
    exec 3<>/dev/tcp/$host/$port; cat <&3 & cat >&3   # bash only, no extra tool

Notes so the substitute doesn't surprise you:
  * There is no '^]' escape character. Disconnect with Ctrl-C or Ctrl-D.
  * curl telnet:// speaks the telnet protocol (option negotiation, CRLF), so it
    behaves closest to the real thing.
  * socat / nc / bash give you a RAW TCP pipe instead: no telnet negotiation, and
    lines end in bare LF — append ',crlf' to socat if the peer wants CRLF.
──────────────────────────────────────────────────────────────────
EOF

if command -v curl >/dev/null 2>&1; then
    exec curl telnet://"$host:$port"
elif command -v socat >/dev/null 2>&1; then
    exec socat - "TCP:$host:$port"
elif command -v ncat >/dev/null 2>&1; then
    exec ncat -- "$host" "$port"
elif command -v nc >/dev/null 2>&1; then
    exec nc -- "$host" "$port"
fi

# Fallback: bash built-in /dev/tcp (no external tool required)
if ! exec 3<>"/dev/tcp/$host/$port"; then
    echo "telnet(fake): could not connect to $host:$port" >&2
    exit 1
fi
cat <&3 &
relay=$!
cat >&3
kill "$relay" 2>/dev/null
